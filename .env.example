# ============================================================
# SCVA Members Management — Environment Variables Template
# ============================================================
# Copy this file to `.env` and fill in real values.
# NEVER commit `.env` to version control.
# ============================================================

# ---------- Database (REQUIRED) ----------
# PostgreSQL connection string
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgres://user:password@localhost:5432/scva_db

# ---------- Sessions (REQUIRED in production) ----------
# Generate a strong random secret:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=replace_me_with_a_long_random_string

# ---------- First-boot admin password (REQUIRED on first boot only) ----------
# Used ONCE to create the default `admin` user.
# Must be at least 8 characters. The user will be forced to change it
# on first login. Remove this variable after the first successful boot.
ADMIN_INITIAL_PASSWORD=changeMe_on_first_login

# ---------- Server ----------
# Port the Express server listens on
PORT=5000

# Environment mode: development | production
NODE_ENV=development

# ---------- PDF Export (OPTIONAL) ----------
# Path to a Chromium binary for server-side PDF generation.
# If unset, defaults to `/usr/bin/chromium`.
# Without Chromium, the /api/members/:id/pdf endpoint returns 500.
# CHROME_PATH=/usr/bin/chromium
